{
  "name": "grundschutz-plusplus-catalog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "npm run build:data && vite",
    "clean:release-artifacts": "node scripts/clean-release-artifacts.mjs",
    "build:data": "node scripts/build-catalog.mjs",
    "build": "npm run clean:release-artifacts && npm run build:data && tsc -b && node scripts/check-legal-placeholders.mjs && vite build",
    "preview": "vite preview --strictPort --host 127.0.0.1 --port 4173",
    "test:unit": "vitest run",
    "check:release-hygiene": "npm run clean:release-artifacts && node scripts/check-release-hygiene.mjs",
    "check:headers": "node scripts/check-security-headers.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:dev": "node scripts/audit-dev-policy.mjs",
    "qa:lighthouse": "lhci autorun --config=./lighthouserc.json",
    "qa:a11y": "playwright test --config=playwright.a11y.config.ts",
    "qa": "npm run build && npm run test:unit && npm run check:release-hygiene && start-server-and-test preview http://127.0.0.1:4173 \"npm run qa:lighthouse && npm run qa:a11y\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.0",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.4",
    "vitest": "^4.0.18"
  }
}
